    <content><![CDATA[<figure class="highlight html"><table><tr><td class="code"><pre><span class="line"><span class="meta">&lt;!DOCTYPE <span class="keyword">html</span>&gt;</span><span class="comment">&lt;!-- 此标签表示告诉浏览器，本文件是html类型文件--&gt;</span></span><br><span class="line"><span class="tag">&lt;<span class="name">html</span>&gt;</span></span><br><span class="line">    <span class="tag">&lt;<span class="name">head</span>&gt;</span><span class="tag">&lt;<span class="name">head</span>&gt;</span><span class="comment">&lt;!--标签为头部元素的容器，在里面存放各种头部元素--&gt;</span></span><br><span class="line">        <span class="tag">&lt;<span class="name">title</span>&gt;</span>第一个程序<span class="tag">&lt;/<span class="name">title</span>&gt;</span><span class="comment">&lt;!--此标签里的内容将展示在网页栏上--&gt;</span></span><br><span class="line">        <span class="comment">&lt;!-- http-equiv和content 配套使用，refresh表示刷新，content中的数字表示刷新间隔时间，如果在后面加上分号，跟一个URL，就可以跳转到另一个网址--&gt;</span></span><br><span class="line">        <span class="comment">&lt;!--meta元素神奇且巧妙，它里面的内容并不是直接展示在网页中，但是可以被爬虫和搜索引擎的数据获取--&gt;</span></span><br><span class="line">        <span class="tag">&lt;<span class="name">meta</span> <span class="attr">http-equiv</span>=<span class="string">&quot;refresh&quot;</span> <span class="attr">content</span>=<span class="string">&quot;2 ; https://www.bilibili.com/video/BV1QW411N762?p=5&amp;spm_id_from=pageDriver&amp;vd_source=9c092468448ddefc0af6b7e082ad35aa&quot;</span>&gt;</span></span><br><span class="line">        <span class="tag">&lt;<span class="name">meta</span> <span class="attr">name</span>=<span class="string">&quot;viewport&quot;</span> <span class="attr">content</span>=<span class="string">&quot;width=device-width, initial-scale=1.0&quot;</span>&gt;</span><span class="comment">&lt;!--让网站在不同的设备都能自适应布局--&gt;</span></span><br><span class="line">    <span class="tag">&lt;/<span class="name">head</span>&gt;</span></span><br><span class="line">    <span class="tag">&lt;<span class="name">body</span>&gt;</span><span class="comment">&lt;!--网页的主体部分，即用户所看到的内容的容器--&gt;</span></span><br><span class="line">        <span class="tag">&lt;<span class="name">h1</span>&gt;</span>Hello World<span class="tag">&lt;/<span class="name">h1</span>&gt;</span><span class="comment">&lt;!--h代表标题，一共有h1-h6这几个标题，每一个的大小都不一样--&gt;</span></span><br><span class="line">        <span class="tag">&lt;<span class="name">img</span> <span class="attr">src</span>=<span class="string">&quot;C:\Users\hp\Pictures\Saved Pictures\forest.jpg&quot;</span> <span class="attr">alt</span>=<span class="string">&quot;森林&quot;</span> <span class="attr">width</span>=<span class="string">&quot;256px&quot;</span> <span class="attr">height</span>=<span class="string">&quot;256px&quot;</span>&gt;</span></span><br><span class="line">        <span class="tag">&lt;<span class="name">p</span>&gt;</span>I am ruijie<span class="tag">&lt;/<span class="name">p</span>&gt;</span></span><br><span class="line">    <span class="tag">&lt;/<span class="name">body</span>&gt;</span></span><br><span class="line"></span><br><span class="line"><span class="tag">&lt;/<span class="name">html</span>&gt;</span></span><br></pre></td></tr></table></figure>

